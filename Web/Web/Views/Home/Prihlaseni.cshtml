@{
    ViewData["Title"] = "Přihlášení";
}

<h1 class="h1">Přihlášení</h1>

<section class="contact-section">
    <div class="contact-box wide">
        <h2>Přihlaste se do svého účtu</h2>
        @if (TempData["Uspech"] != null)
        {
            <p class="uspech">@TempData["Uspech"]</p>
        }
        @if (ViewBag.Chyba != null)
        {
            <p class="chyba">@ViewBag.Chyba</p>
        }
        <form method="post" asp-controller="Home" asp-action="Prihlaseni">
            <div class="form-group">
                <label for="jmeno">Jméno</label>
                <input type="text" id="jmeno" name="jmeno" required />
            </div>
            <div class="form-group">
                <label for="heslo">Heslo</label>
                <input type="password" id="heslo" name="heslo" required />
            </div>
            <button type="submit" class="form-btn">Přihlásit se</button>
        </form>
        <p>Nemáte účet? <a asp-controller="Home" asp-action="Registrace">Zaregistrujte se</a></p>
    </div>
</section>
